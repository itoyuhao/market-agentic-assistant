# Copy to .env and fill in real values. .env is gitignored.

# FRED API — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# NewsAPI — https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# Anthropic API — OPTIONAL if you have Claude Code logged in.
# claude-agent-sdk spawns the `claude` CLI as a subprocess, so it uses
# whatever auth Claude Code already has (subscription login OK).
# Only set this if you want to bypass Claude Code and pay per-token via API.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: override default Claude model
# CLAUDE_MODEL=claude-sonnet-4-6
